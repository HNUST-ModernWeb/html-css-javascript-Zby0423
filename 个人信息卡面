<!DOCTYPE html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>个人信息卡片</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Arial', sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .container {
      text-align: center;
      max-width: 500px;
      width: 100%;
    }

    h1 {
      color: white;
      margin-bottom: 30px;
      font-size: 2.5rem;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .card {
      background: white;
      border-radius: 20px;
      padding: 30px;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
      transition: transform 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .avatar-section {
      margin-bottom: 25px;
    }

    .avatar {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid #667eea;
      margin-bottom: 15px;
    }

    .avatar-upload {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .avatar-upload-btn {
      background: #667eea;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 20px;
      cursor: pointer;
      font-size: 14px;
      transition: background 0.3s ease;
    }

    .avatar-upload-btn:hover {
      background: #5a67d8;
    }

    .avatar-input {
      display: none;
    }

    .info-section {
      margin-bottom: 25px;
    }

    .info-item {
      margin-bottom: 20px;
    }

    .info-label {
      display: block;
      font-weight: bold;
      color: #4a5568;
      margin-bottom: 8px;
      text-align: left;
    }

    .info-input {
      width: 100%;
      padding: 12px;
      border: 2px solid #e2e8f0;
      border-radius: 10px;
      font-size: 16px;
      transition: border-color 0.3s ease;
    }

    .info-input:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .save-btn {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border: none;
      padding: 15px 30px;
      border-radius: 25px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      width: 100%;
    }

    .save-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    .save-btn:active {
      transform: translateY(0);
    }

    .display-section {
      margin-top: 25px;
      padding-top: 25px;
      border-top: 2px solid #e2e8f0;
    }

    .display-name {
      font-size: 1.5rem;
      font-weight: bold;
      color: #2d3748;
      margin-bottom: 10px;
    }

    .display-bio {
      color: #718096;
      line-height: 1.6;
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>个人信息卡片</h1>

    <div class="card">
      <div class="avatar-section">
        <div class="avatar-upload">
          <img id="avatar" class="avatar"
            src="data:image/svg+xml;base64,"
            alt="头像">
          <input type="file" id="avatarInput" class="avatar-input" accept="image/*">
          <button class="avatar-upload-btn" onclick="document.getElementById('avatarInput').click()">上传头像</button>
        </div>
      </div>

      <div class="info-section">
        <div class="info-item">
          <label class="info-label">姓名</label>
          <input type="text" id="nameInput" class="info-input" placeholder="请输入您的姓名" value="">
        </div>

        <div class="info-item">
          <label class="info-label">个人简介</label>
          <textarea id="bioInput" class="info-input" placeholder="请输入您的个人简介" rows="3"></textarea>
        </div>
      </div>

      <button class="save-btn" onclick="saveInfo()">保存信息</button>

      <div class="display-section">
        <div class="display-name" id="displayName"></div>
        <div class="display-bio" id="displayBio"></div>
      </div>
    </div>
  </div>

  <script>
    const avatarInput = document.getElementById('avatarInput');
    const avatar = document.getElementById('avatar');
    const nameInput = document.getElementById('nameInput');
    const bioInput = document.getElementById('bioInput');
    const displayName = document.getElementById('displayName');
    const displayBio = document.getElementById('displayBio');

    avatarInput.addEventListener('change', function (e) {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function (e) {
          avatar.src = e.target.result;
        };
        reader.readAsDataURL(file);
      }
    });

    function saveInfo() {
      const name = nameInput.value.trim();
      const bio = bioInput.value.trim();

      if (name) {
        displayName.textContent = name;
      }

      if (bio) {
        displayBio.textContent = bio;
      }

      alert('信息保存成功！');
    }

    nameInput.addEventListener('input', function () {
      if (nameInput.value.trim()) {
        displayName.textContent = nameInput.value;
      }
    });

    bioInput.addEventListener('input', function () {
      if (bioInput.value.trim()) {
        displayBio.textContent = bioInput.value;
      }
    });
  </script>
</body>

</html>
